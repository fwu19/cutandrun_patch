workDir = '/hpc/temp/_SR/Genomics/users/fwu/nextflow/cutandrun/work'

process {
    executor = 'slurm'
    queue = 'campus-new'
	errorStrategy = 'retry'
	maxRetries = 1
	module = ['fhR/4.1.2-foss-2021b', 'Bowtie2/2.4.2-GCC-10.2.0', 'BEDTools/2.30.0-GCC-10.2.0', 'SAMtools/1.11-GCC-10.2.0']

        withName: FASTQC {
        cpus = 1
        memory = '12 GB'

    }

}

env {
	MPLCONFIGDIR = '/hpc/temp/_SR/Genomics/users/fwu/nextflow/cache'
	R_LIBS = '/fh/fast/_SR/Genomics/user/fwu/R/x86_64-pc-linux-gnu-library/4.1' 
}

report {
    enabled = true
    file = "nextflow.report.html"
    overwrite = true
}